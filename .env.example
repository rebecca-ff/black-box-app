# Anthropic API key — used SERVER-SIDE ONLY by /api/brief.
# Never prefix with NEXT_PUBLIC_ and never commit the real value.
# Set it locally in .env.local, and in Vercel: Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=

# Supabase — persistence + auth. URL + anon key are public (browser); the service
# role key is SERVER-ONLY (used by API routes, e.g. storing TikTok tokens).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# TikTok Login Kit + Display API — connects a creator's TikTok and reads their
# real-time video metrics (views/likes/comments/shares) directly from TikTok.
# Register the redirect URI <APP_URL>/api/tiktok/callback in your TikTok app and
# request the user.info.* + video.list scopes.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Public base URL used to build the OAuth redirect (falls back to the request host).
NEXT_PUBLIC_APP_URL=
